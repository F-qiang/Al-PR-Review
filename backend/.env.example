# GitHub Token（可选，提高 API 限额，支持私有仓库）
GITHUB_TOKEN=

# LLM 配置（OpenAI 兼容接口，DeepSeek / 通义 / OpenAI 均可）
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 数据库（默认 SQLite，无需额外安装）
DATABASE_URL=sqlite+aiosqlite:///./prreview.db

# CORS
CORS_ORIGINS=http://localhost:3000

# 七牛云 Kodo（可选，用于上传 Markdown 报告）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=https://your-cdn-domain.com
