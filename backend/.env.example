# GitHub Token（可选，提高 API 限额，支持私有仓库）
GITHUB_TOKEN=

# GitHub Webhook 密钥（可选，用于签名校验）
GITHUB_WEBHOOK_SECRET=

# 分析完成后自动回评到 PR（需 GitHub Token 有 repo 写权限）
GITHUB_AUTO_COMMENT=true

# LLM 配置
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 数据库（固定使用 backend/prreview.db，避免因启动目录变化而切换数据库）
DATABASE_URL=sqlite+aiosqlite:///D:/Users/DELL/Desktop/七牛云/backend/prreview.db

# CORS
CORS_ORIGINS=http://localhost:3000

# 七牛云 Kodo（可选，用于上传 Markdown 报告）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=https://your-cdn-domain.com
